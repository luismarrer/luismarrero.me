---
import Layout from "@/layouts/Layout.astro"
import Section from "@/components/Section.astro"
import Tags from "@/components/reactive/Tags.svelte"
import CosmeticText from "@/components/CosmeticText.astro"
import Poems from "@/components/Poems.astro"
import PostCard from "@/components/PostCard.astro"

import { siteTitle, siteDescription } from "@/data/site.json"
import { userGithubUsername } from "@/data/user-contact.json"
import { userProfessionalDescription } from "@/data/user-professional.json"
import { userIntroduction, userName } from "@/data/user-personal.json"
import { getPostTags, getPublishedPosts } from "@/lib/posts"

const userPicture = `https://github.com/${userGithubUsername}.png?size=384`
const allPosts = await getPublishedPosts()
const featuredPosts = allPosts.slice(0, 6)
const hasMorePosts = allPosts.length > featuredPosts.length

const heroTags = getPostTags(allPosts).map((tag) => tag.name)

const cosmeticTexts: { [section: string]: string } = {
  header: "BACKROOM",
  hero: "CLICK ON A TAG",
  about: "ABOUT ME",
}
---

<Layout
  siteTitle={siteTitle}
  siteDescription={siteDescription}
  headerCosmeticText={cosmeticTexts.header}
>
  <!-- HERO -->
  <Section
    class="relative flex min-h-72 pl-4 bg-radial-[at_50%_10%] from-accent/10 to-transparent"
  >
    <div class="max-w-md m-auto text-center">
      <h1 class="text-2xl">{userProfessionalDescription}</h1>
      <Tags tags={heroTags} />
    </div>
    <CosmeticText text={cosmeticTexts.hero} vertical />
  </Section>

  <!-- AI POEMS -->
  <Section class="text-center p-4">
    <Poems />
  </Section>

  <!-- POSTS -->
  <Section class="p-3 sm:p-4">
    <div class="grid min-w-0 grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4 md:grid-cols-3">
      {featuredPosts.map((post) => <PostCard post={post} />)}
    </div>
    {
      hasMorePosts && (
        <p class="mt-4 text-center">
          <a
            href="/posts"
            class="inline-block rounded-interactive border border-edge px-4 py-2 duration-200 hover:border-accent hover:text-accent"
          >
            Browse all posts
          </a>
        </p>
      )
    }
  </Section>

  <!-- ABOUT -->
  <Section
    class="relative flex min-h-96 bg-radial-[at_50%_90%] from-accent/10 to-transparent"
  >
    <span class="absolute"
      ><CosmeticText text={cosmeticTexts.about} vertical /></span
    >
    <div
      class="flex flex-col gap-16 max-w-3xl mx-auto px-8 pt-32 pb-16 md:flex-row md:p-16"
    >
      <div
        class="group/image aspect-square h-48 w-48 mx-auto my-auto rounded-interactive bg-accent md:mx-0"
      >
        <img
          class="h-48 w-48 scale-110 -rotate-z-12 overflow-clip object-cover rounded-interactive group-hover/image:scale-[101%] group-hover/image:-rotate-z-0 duration-200"
          src={userPicture}
          width="384"
          height="384"
          loading="lazy"
          decoding="async"
          alt={`${userName}'s profile picture.`}
        />
      </div>

      <div class="my-auto flex flex-col gap-4 text-pretty">
        <h2 class="text-xl">Hi.</h2>
        {userIntroduction.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </Section>
</Layout>
