---
import Layout from "@/layouts/Layout.astro"
import Section from "@/components/Section.astro"
import Posts from "@/components/reactive/Posts.svelte"
import Tags from "@/components/reactive/Tags.svelte"
import { getPostTags, getPublishedPosts, toPostCardData } from "@/lib/posts"

const allPosts = await getPublishedPosts()
const tags = getPostTags(allPosts)
const posts = allPosts.map(toPostCardData)
---

<Layout
  siteTitle="Posts"
  siteDescription="Technical posts and personal notes by Luis Marrero."
  headerCosmeticText="POSTS"
>
  <Section class="p-4 sm:p-8">
    <div class="mx-auto max-w-6xl">
      <h1 class="text-2xl">Posts</h1>
      <p class="mt-2 text-pretty text-primary-foreground/75">
        Technical posts and personal notes.
      </p>

      <Tags client:load tags={tags} showCounts class="mt-6 text-sm sm:text-base" />

      <div class="mt-6">
        <Posts client:load posts={posts} />
      </div>
    </div>
  </Section>
</Layout>
