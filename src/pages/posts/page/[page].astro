---
import Layout from "@/layouts/Layout.astro"
import Section from "@/components/Section.astro"
import PostArchive from "@/components/PostArchive.astro"
import {
  getPostArchiveStaticPaths,
  type PostsPage,
} from "@/lib/posts"
import type { PostTag } from "@/lib/post-tags"

export const getStaticPaths = getPostArchiveStaticPaths

interface Props {
  page: PostsPage
  tags: PostTag[]
}

const { page, tags } = Astro.props
---

<Layout
  siteTitle={`Posts - Page ${page.currentPage}`}
  siteDescription="Technical posts and personal notes by Luis Marrero."
  headerCosmeticText="POSTS"
>
  <Section class="p-4 sm:p-8">
    <PostArchive
      page={page}
      tags={tags}
      title="Posts"
      description="Technical posts and personal notes."
    />
  </Section>
</Layout>
