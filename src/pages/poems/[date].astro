---
import Layout from "@/layouts/Layout.astro"
import Section from "@/components/Section.astro"
import { formatPoemDate, getPoemStaticPaths } from "@/lib/poems"

export const getStaticPaths = getPoemStaticPaths

const poem = Astro.props

const formattedDate = formatPoemDate(poem.date)

const poemsBackScript = `
if (
    event.button === 0 &&
    !event.metaKey &&
    !event.ctrlKey &&
    !event.altKey &&
    !event.shiftKey &&
    window.__lmPoemsReturnPath === "/poems/${poem.date}"
) {
    event.preventDefault();
    event.stopPropagation();
    history.back();
}
`
---

<Layout
    siteTitle={poem.title}
    siteDescription={`An AI poem in Spanish about code, written on ${poem.date}.`}
    headerCosmeticText="POEM"
    lang="es"
>
    <Section class="p-4 sm:p-8">
        <div class="mx-auto max-w-2xl text-center">
            <a
                href={`/poems#poem-${poem.date}`}
                data-poems-back
                onclick={poemsBackScript}
                class="text-sm text-primary-foreground/75 duration-200 hover:text-accent"
            >
                ← All poems
            </a>

            <h1 class="mt-4 text-2xl">{poem.title}</h1>

            <pre lang="es" class="mx-auto mt-4 max-w-full overflow-x-auto whitespace-pre-wrap break-words p-2 text-left sm:w-fit">{poem.poem}</pre>

            <p class="mt-4">
                <em class="text-primary-foreground/75">
                    <time datetime={poem.date}>{formattedDate}</time> — Model:{" "}
                    {poem.model}
                </em>
            </p>
        </div>
    </Section>
</Layout>
