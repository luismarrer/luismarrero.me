---
import Layout from "@/layouts/Layout.astro"
import Section from "@/components/Section.astro"
import PoemArchive from "@/components/PoemArchive.astro"
import { getPoemArchiveStaticPaths, type PoemsPage } from "@/lib/poems"

export const getStaticPaths = getPoemArchiveStaticPaths

const page = Astro.props as PoemsPage
---

<Layout
    siteTitle={`AI Poems - Page ${page.currentPage}`}
    siteDescription="A daily poem written by an AI in Spanish about code."
    headerCosmeticText="POEMS"
>
    <Section class="p-4 sm:p-8">
        <PoemArchive {...page} />
    </Section>
</Layout>
