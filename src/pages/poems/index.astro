---
import Layout from "@/layouts/Layout.astro"
import Section from "@/components/Section.astro"
import { getCollection } from "astro:content"

// Newest first. Dates are "YYYY-MM-DD" strings, so they sort lexicographically.
const poems = (await getCollection("ai_poems"))
    .map((p) => p.data)
    .sort((a, b) => b.date.localeCompare(a.date))

const formatDate = (date: string) =>
    new Date(`${date}T00:00:00`).toLocaleDateString("en-us", {
        year: "numeric",
        month: "short",
        day: "numeric",
    })
---

<Layout
    siteTitle="AI Poems"
    siteDescription="A daily poem written by an AI in Spanish about code."
    headerCosmeticText="POEMS"
>
    <Section class="p-4 sm:p-8">
        <div class="mx-auto max-w-6xl">
            <h1 class="text-2xl">AI Poems</h1>
            <p class="mt-2 text-pretty text-primary-foreground/75">
                One poem a day, written by an AI in Spanish about code.
            </p>

            <div
                class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4 md:grid-cols-3"
            >
                {
                    poems.map((poem) => (
                        <a
                            href={`/poems/${poem.date}`}
                            class="flex h-full min-h-32 min-w-0 flex-col gap-2 rounded-interactive border border-edge bg-linear-to-b from-secondary to-secondary/60 p-3 duration-200 hover:border-accent"
                        >
                            <span class="text-sm text-primary-foreground/75">
                                <time datetime={poem.date}>
                                    {formatDate(poem.date)}
                                </time>
                            </span>
                            <h2 class="break-words text-lg font-semibold">
                                {poem.title}
                            </h2>
                            <span class="mt-auto break-words text-sm text-accent">
                                {poem.model}
                            </span>
                        </a>
                    ))
                }
            </div>
        </div>
    </Section>
</Layout>
