---
import Head from "@/components/Head.astro"
import Header from "@/components/Header.astro"
import Footer from "@/components/Footer.astro"
import Navbar from "@/components/Navbar.astro"
import Analytics from "@vercel/analytics/astro"
import SpeedInsights from "@vercel/speed-insights/astro"
import { ClientRouter } from "astro:transitions"

interface Props {
  siteTitle: string
  siteDescription: string
  headerCosmeticText: string
  lang?: string
}

const { siteTitle, siteDescription, headerCosmeticText, lang = "en" } = Astro.props
---

<!doctype html>
<html lang={lang} class="bg-primary">
  <head>
    <Head pageTitle={siteTitle} pageDescription={siteDescription} />
    <ClientRouter />
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-3 focus:top-3 focus:z-50 focus:rounded-interactive focus:bg-primary-foreground focus:px-3 focus:py-2 focus:text-primary"
    >
      Skip to content
    </a>
    <Navbar />
    <main id="main-content" class="min-h-svh pt-14">
      <Header cosmeticText={headerCosmeticText} />
      <slot />
      <Footer />
    </main>
    <Analytics />
    <SpeedInsights />
  </body>
</html>
