---
interface Props {
  text: string;
  vertical?: boolean;
}

const { text, vertical = false } = Astro.props;
---

<span
  aria-hidden="true"
  style={vertical ? "writing-mode: vertical-lr;" : ""}
  class="block px-2 text-xl font-semibold tracking-[0.3em] text-primary-foreground/70"
>
  {text}
</span>
