---
import { getTodayPoem } from "@/lib/poems";

const todayPoem = await getTodayPoem();
---

<h2 class="text-2xl">AI Poems</h2>
<div class="mx-auto max-w-2xl">
    {
        todayPoem ? (
            <>
                <h3 class="text-xl" lang="es">
                    {todayPoem.title}
                </h3>
                <pre
                    lang="es"
                    class="mx-auto max-w-full overflow-x-auto whitespace-pre-wrap break-words p-2 text-left sm:w-fit"
                >
                    {todayPoem.poem}
                </pre>
                <p class="text-balance">
                    One poem a day, written by an AI in Spanish about code.{" "}
                    <br />
                    Every day, a new poem awaits you!
                </p>
                <p>
                    <em>
                        {todayPoem.date} — Model: {todayPoem.model}
                    </em>
                </p>
            </>
        ) : (
            <p>Today's poem hasn't been written yet. Check back soon.</p>
        )
    }
</div>
