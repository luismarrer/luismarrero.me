---
import {
    formatPoemDate,
    getPoemsPagePath,
    type PoemsPage,
} from "@/lib/poems"

const { currentPage, poems, pageSize, totalPages, totalPoems } =
    Astro.props as PoemsPage

const pagePath = getPoemsPagePath(currentPage)
const firstVisiblePoem = totalPoems === 0 ? 0 : (currentPage - 1) * pageSize + 1
const lastVisiblePoem = Math.min(currentPage * pageSize, totalPoems)

const getPoemReturnScript = (date: string) => `
if (event.button !== 0 || event.metaKey || event.ctrlKey || event.altKey || event.shiftKey) return;

const card = event.currentTarget;
const rect = card.getBoundingClientRect();
const minTop = 80;
const targetTop = Math.max(rect.top, minTop);
const scrollY = Math.max(window.scrollY + rect.top - targetTop, 0);
const archivePath = "${pagePath}";

window.__lmPoemsReturnPath = "/poems/${date}";

const saveReturnState = () => {
    const currentPath = window.location.pathname.replace(/\\/$/, "") || "/";
    if (currentPath !== archivePath) return;

    history.replaceState(
        { ...(history.state || {}), scrollX: window.scrollX, scrollY },
        "",
        archivePath + "#poem-${date}",
    );
};

document.addEventListener("astro:before-swap", saveReturnState, { once: true });
window.setTimeout(saveReturnState, 0);
`
---

<div class="mx-auto max-w-6xl">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
            <h1 class="text-2xl">AI Poems</h1>
            <p class="mt-2 text-pretty text-primary-foreground/75">
                One poem a day, written by an AI in Spanish about code.
            </p>
        </div>

        <p class="text-sm text-primary-foreground/65">
            {firstVisiblePoem}-{lastVisiblePoem} of {totalPoems}
        </p>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4 md:grid-cols-3">
        {
            poems.map((poem) => (
                <a
                    id={`poem-${poem.date}`}
                    data-poem-card
                    data-poem-date={poem.date}
                    href={`/poems/${poem.date}`}
                    onclick={getPoemReturnScript(poem.date)}
                    class="flex h-full min-h-32 min-w-0 scroll-mt-24 flex-col gap-2 rounded-interactive border border-edge bg-linear-to-b from-secondary to-secondary/60 p-3 duration-200 hover:border-accent"
                >
                    <span class="text-sm text-primary-foreground/75">
                        <time datetime={poem.date}>
                            {formatPoemDate(poem.date)}
                        </time>
                    </span>
                    <h2 class="break-words text-lg font-semibold">
                        <span lang="es">{poem.title}</span>
                    </h2>
                    <span class="mt-auto break-words text-sm text-accent">
                        {poem.model}
                    </span>
                </a>
            ))
        }
    </div>

    {
        totalPages > 1 && (
            <nav
                class="mt-8 flex flex-wrap items-center justify-between gap-3 border-t border-edge pt-4"
                aria-label="Poem archive pagination"
            >
                <a
                    href={getPoemsPagePath(Math.max(currentPage - 1, 1))}
                    aria-disabled={currentPage === 1 ? "true" : undefined}
                    class:list={[
                        "rounded-interactive border border-edge px-4 py-2 text-sm duration-200 hover:border-accent hover:text-accent",
                        currentPage === 1 && "pointer-events-none opacity-40",
                    ]}
                >
                    Previous
                </a>

                <span class="text-sm text-primary-foreground/70">
                    Page {currentPage} of {totalPages}
                </span>

                <a
                    href={getPoemsPagePath(Math.min(currentPage + 1, totalPages))}
                    aria-disabled={currentPage === totalPages ? "true" : undefined}
                    class:list={[
                        "rounded-interactive border border-edge px-4 py-2 text-sm duration-200 hover:border-accent hover:text-accent",
                        currentPage === totalPages && "pointer-events-none opacity-40",
                    ]}
                >
                    Next
                </a>
            </nav>
        )
    }
</div>
